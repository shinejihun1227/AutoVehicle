<launch>
  <arg name="camera_port" default="1001" />
  <arg name="save_samples" default="false" />
  <arg name="publish_debug_image" default="true" />

  <include file="$(find yeoms_camera_bridge)/launch/camera_udp_receiver.launch">
    <arg name="camera_name" value="front" />
    <arg name="camera_port" value="$(arg camera_port)" />
    <arg name="image_topic" value="/sensors/camera/front/compressed" />
    <arg name="frame_info_topic" value="/perception/camera/front/frame_info" />
    <arg name="frame_id" value="front_camera" />
    <arg name="save_samples" value="$(arg save_samples)" />
  </include>

  <include file="$(find yeoms_camera_perception)/launch/camera_perception.launch">
    <arg name="camera_name" value="front" />
    <arg name="image_topic" value="/sensors/camera/front/compressed" />
    <arg name="lane_offset_topic" value="/perception/camera/front/lane_offset_px" />
    <arg name="traffic_light_topic" value="/perception/camera/front/traffic_light_state" />
    <arg name="stop_line_topic" value="/perception/camera/front/stop_line_detected" />
    <arg name="debug_topic" value="/perception/camera/front/debug/compressed" />
    <arg name="publish_debug_image" value="$(arg publish_debug_image)" />
  </include>
</launch>
