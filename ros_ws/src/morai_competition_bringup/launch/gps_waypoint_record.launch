<launch>
  <arg name="output_file" default="" />
  <arg name="target_speed_mps" default="1.0" />
  <arg name="min_distance_m" default="0.2" />
  <arg name="min_time_s" default="0.1" />
  <arg name="use_measured_speed" default="false" />

  <!-- UDP GPS -> /localization/ego_pose, /localization/ego_twist -->
  <include file="$(find yeoms_udp_bridge)/launch/udp_gps_localization.launch" />

  <!-- UDP IMU -> /udp_bridge/imu, /udp_bridge/imu_debug -->
  <include file="$(find yeoms_udp_bridge)/launch/udp_imu.launch" />

  <!-- Record the driven localization path as a Stanley-compatible CSV. -->
  <include file="$(find yeoms_control)/launch/record_waypoints.launch">
    <arg name="output_file" value="$(arg output_file)" />
    <arg name="target_speed_mps" value="$(arg target_speed_mps)" />
    <arg name="min_distance_m" value="$(arg min_distance_m)" />
    <arg name="min_time_s" value="$(arg min_time_s)" />
    <arg name="use_measured_speed" value="$(arg use_measured_speed)" />
  </include>
</launch>
