rospack profile


roslaunch yeoms_bringup record_gps_path.launch output_file:=$HOME/morai_recorded_paths/01.csv

roslaunch yeoms_bringup drive_pure_pursuit.launch \
  waypoint_file:=$HOME/morai_recorded_paths/01.csv \
  target_speed_mps:=1.0 \
  max_speed_mps:=1.0
