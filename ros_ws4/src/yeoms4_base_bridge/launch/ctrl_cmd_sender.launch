<launch>
  <arg name="config_file" default="$(find yeoms4_base_bridge)/config/base_bridge.yaml" />
  <arg name="max_speed_mps" default="1.2" />
  <rosparam command="load" file="$(arg config_file)" />
  <param name="/ctrl_cmd/max_speed_mps" value="$(arg max_speed_mps)" />

  <node pkg="yeoms4_base_bridge"
        type="ctrl_cmd_sender.py"
        name="ctrl_cmd_sender"
        output="screen" />
</launch>
