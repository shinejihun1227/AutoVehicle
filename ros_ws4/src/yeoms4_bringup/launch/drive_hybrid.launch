<launch>
  <arg name="waypoint_file" default="$(env HOME)/morai_recorded_paths/01.csv" />
  <arg name="target_speed_mps" default="1.0" />
  <arg name="max_speed_mps" default="1.0" />
  <arg name="use_csv_target_speed" default="false" />
  <arg name="hybrid_stanley_weight" default="0.45" />
  <arg name="stanley_gain" default="0.35" />
  <arg name="softening_gain" default="2.0" />
  <arg name="min_curve_speed_mps" default="2.5" />
  <arg name="min_lookahead_m" default="3.0" />
  <arg name="max_lookahead_m" default="12.0" />
  <arg name="start_from_first_waypoint" default="true" />
  <arg name="require_start_pose" default="false" />
  <arg name="start_position_tolerance_m" default="3.0" />
  <arg name="start_yaw_tolerance_rad" default="0.7" />

  <include file="$(find yeoms4_base_bridge)/launch/gps_localization.launch" />

  <include file="$(find yeoms4_hybrid_controller)/launch/hybrid_controller.launch">
    <arg name="waypoint_file" value="$(arg waypoint_file)" />
    <arg name="target_speed_mps" value="$(arg target_speed_mps)" />
    <arg name="max_speed_mps" value="$(arg max_speed_mps)" />
    <arg name="use_csv_target_speed" value="$(arg use_csv_target_speed)" />
    <arg name="hybrid_stanley_weight" value="$(arg hybrid_stanley_weight)" />
    <arg name="stanley_gain" value="$(arg stanley_gain)" />
    <arg name="softening_gain" value="$(arg softening_gain)" />
    <arg name="min_curve_speed_mps" value="$(arg min_curve_speed_mps)" />
    <arg name="min_lookahead_m" value="$(arg min_lookahead_m)" />
    <arg name="max_lookahead_m" value="$(arg max_lookahead_m)" />
    <arg name="start_from_first_waypoint" value="$(arg start_from_first_waypoint)" />
    <arg name="require_start_pose" value="$(arg require_start_pose)" />
    <arg name="start_position_tolerance_m" value="$(arg start_position_tolerance_m)" />
    <arg name="start_yaw_tolerance_rad" value="$(arg start_yaw_tolerance_rad)" />
  </include>

  <include file="$(find yeoms4_base_bridge)/launch/ctrl_cmd_sender.launch">
    <arg name="max_speed_mps" value="$(arg max_speed_mps)" />
  </include>
</launch>
