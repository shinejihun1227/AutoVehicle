1. 전체 최신화
cd ~/AutoVehicle
git pull


2. 대회 경로 파일 위치
대회 경로 파일은 여기에 두세요.
mkdir -p ~/morai_recorded_paths
cp ~/Downloads/2026_molit_comp_global_path.txt ~/morai_recorded_paths/

이후 실행할 때 공통으로 이 경로를 씁니다.
$HOME/morai_recorded_paths/2026_molit_comp_global_path.txt


3. ros_ws: Pure Pursuit


cd ~/morai_stanley_ws

rm -rf src/yeoms_base_bridge src/yeoms_bringup src/yeoms_path_recorder src/yeoms_pure_pursuit

cp -r ~/AutoVehicle/ros_ws/src/yeoms_base_bridge src/
cp -r ~/AutoVehicle/ros_ws/src/yeoms_bringup src/
cp -r ~/AutoVehicle/ros_ws/src/yeoms_path_recorder src/
cp -r ~/AutoVehicle/ros_ws/src/yeoms_pure_pursuit src/

chmod +x src/yeoms_base_bridge/scripts/*.py
chmod +x src/yeoms_path_recorder/scripts/*.py
chmod +x src/yeoms_pure_pursuit/scripts/*.py

source /opt/ros/noetic/setup.bash
catkin_make
source devel/setup.bash
rospack profile
실행:
roslaunch yeoms_bringup drive_pure_pursuit.launch \
  waypoint_file:=$HOME/morai_recorded_paths/2026_molit_comp_global_path.txt \
  target_speed_mps:=3.0 \
  max_speed_mps:=3.0



